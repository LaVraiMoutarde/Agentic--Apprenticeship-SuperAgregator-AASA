# ═══════════════════════════════════════════════════════════════════
# Alternance Search — Configuration par variables d'environnement
# ═══════════════════════════════════════════════════════════════════
# Copiez ce fichier en .env et ajustez les valeurs :
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────
# APP_PROJECT_ROOT=.

# ── Base de données ───────────────────────────────────────────────
DB_URL=sqlite:///data/offres.db
# DB_ECHO=false

# ── Scraping ──────────────────────────────────────────────────────
# SCRAPER_MIN_DELAY_SEC=2.0
# SCRAPER_REQUEST_TIMEOUT_SEC=30.0
# SCRAPER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
# SCRAPER_MAX_OFFERS_PER_SOURCE=500

# ── Navigateur Playwright ─────────────────────────────────────────
# Chemin vers Chromium (Brave, Chrome, Edge...). Laisser vide = auto-détection.
BROWSER_EXECUTABLE_PATH=
# BROWSER_HEADLESS=true
# BROWSER_MIN_DELAY_SEC=1.0
# BROWSER_MAX_DELAY_SEC=3.0

# ── Embeddings ────────────────────────────────────────────────────
# Modèle sentence-transformers (1024-dim, multilingue FR/EN)
EMBED_MODEL_NAME=intfloat/multilingual-e5-large
# EMBED_DIM=1024
# EMBED_BATCH_SIZE=32
# EMBED_DEVICE=cpu
# EMBED_NORMALIZE=true

# ── Index vectoriel turbovec ──────────────────────────────────────
# TV_BIT_WIDTH=4
# TV_INDEX_PATH=data/index.tvim

# ── Scoring LLM (optionnel) ───────────────────────────────────────
# Fournisseur : ollama (local) ou openai (cloud ou local compatible)
SCORER_PROVIDER=ollama
SCORER_MODEL=qwen2.5:7b
# URL de l'API compatible OpenAI (Ollama par défaut sur port 11434)
SCORER_BASE_URL=http://localhost:11434/v1
# SCORER_TEMPERATURE=0.0
# SCORER_MAX_OFFERS_PER_CALL=20
# SCORER_TIMEOUT_SEC=60.0
# SCORER_MAX_LLM_CANDIDATES=50

# ── Export Excel ──────────────────────────────────────────────────
# EXPORT_OUTPUT_DIR=exports/
# EXPORT_MAX_ROWS_PER_FILE=10000
